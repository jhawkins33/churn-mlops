# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit it.

# Get this via: terraform output sagemaker_role_arn (from infrastructure/)
SAGEMAKER_ROLE_ARN=arn:aws:iam::<your-account-id>:role/churn-mlops-sagemaker-execution-role
AWS_REGION=us-east-1
AWS_PROFILE=churn-mlops-personal
